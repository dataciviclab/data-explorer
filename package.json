{
  "name": "data-explorer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "observable build",
    "dev": "observable preview",
    "preview": "observable preview",
    "generate:catalog": "node scripts/generate_catalog.mjs",
    "generate:observable": "node scripts/generate_observable.mjs",
    "generate:all": "node scripts/generate_observable.mjs",
    "test": "node --test tests/*.test.mjs && python3 -m pytest tests/test_util.py -q --tb=short",
    "test:js": "node --test tests/*.test.mjs",
    "test:py": "python3 -m pytest tests/ -q --tb=short",
    "test:unit": "node --test tests/"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": "20.x"
  },
  "dependencies": {
    "@observablehq/framework": "^1.13.4",
    "@observablehq/plot": "^0.6.17",
    "duckdb": "^1.4.4",
    "esbuild": "^0.25.1"
  },
  "devDependencies": {
    "git-remote-origin-url": "4.0.0"
  }
}
